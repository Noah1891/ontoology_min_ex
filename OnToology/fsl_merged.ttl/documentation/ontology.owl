<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.softlang.org/ontologies/fsl#"
     xml:base="http://www.softlang.org/ontologies/fsl"
     xmlns:pe="http://www.softlang.org/ontologies/pe#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:tbox="http://www.softlang.org/ontologies/tbox#">
    <owl:Ontology rdf:about="http://www.softlang.org/ontologies/fsl">
        <tbox:commentingPolicy xml:lang="en">See http://www.softlang.org/ontologies/tbox -- the same policy applies here.</tbox:commentingPolicy>
        <tbox:formattingPolicy xml:lang="en">See http://www.softlang.org/ontologies/tbox -- the same policy applies here.</tbox:formattingPolicy>
        <tbox:linkingPolicy xml:lang="en">See http://www.softlang.org/ontologies/tbox -- the same policy applies here.</tbox:linkingPolicy>
        <tbox:metamodelingPolicy xml:lang="en">See http://www.softlang.org/ontologies/tbox -- the same policy applies here.</tbox:metamodelingPolicy>
        <rdfs:comment xml:lang="en">Ontology on the foundations of software languages</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.softlang.org/ontologies/pe#profilingPolicy -->


    <owl:AnnotationProperty rdf:about="http://www.softlang.org/ontologies/pe#profilingPolicy">
        <rdfs:label xml:lang="en">profiling policy</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#commentingPolicy -->


    <owl:AnnotationProperty rdf:about="http://www.softlang.org/ontologies/tbox#commentingPolicy"/>
    


    <!-- http://www.softlang.org/ontologies/tbox#formattingPolicy -->


    <owl:AnnotationProperty rdf:about="http://www.softlang.org/ontologies/tbox#formattingPolicy"/>
    


    <!-- http://www.softlang.org/ontologies/tbox#linkingPolicy -->


    <owl:AnnotationProperty rdf:about="http://www.softlang.org/ontologies/tbox#linkingPolicy"/>
    


    <!-- http://www.softlang.org/ontologies/tbox#metamodelingPolicy -->


    <owl:AnnotationProperty rdf:about="http://www.softlang.org/ontologies/tbox#metamodelingPolicy"/>
    


    <!-- http://www.softlang.org/ontologies/tbox#object -->


    <owl:AnnotationProperty rdf:about="http://www.softlang.org/ontologies/tbox#object">
        <rdfs:comment xml:lang="en">Identifies the object constituent of an issue when the issue concerns a particular assertion; this property designates object role rather than the overall issue target</rdfs:comment>
        <rdfs:label xml:lang="en">object</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Issue_tracking_system"/>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#object"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#IssueEntity"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#predicate -->


    <owl:AnnotationProperty rdf:about="http://www.softlang.org/ontologies/tbox#predicate">
        <rdfs:comment xml:lang="en">Identifies the predicate constituent of an issue when the issue concerns a particular assertion; this property designates predicate role rather than the overall issue target</rdfs:comment>
        <rdfs:label xml:lang="en">predicate</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Issue_tracking_system"/>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#IssueEntity"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#subject -->


    <owl:AnnotationProperty rdf:about="http://www.softlang.org/ontologies/tbox#subject">
        <rdfs:comment xml:lang="en">Identifies the subject constituent of an issue when the issue concerns a particular assertion; this property designates subject role rather than the overall issue target</rdfs:comment>
        <rdfs:label xml:lang="en">subject</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Issue_tracking_system"/>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#subject"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#IssueEntity"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#target -->


    <owl:AnnotationProperty rdf:about="http://www.softlang.org/ontologies/tbox#target">
        <rdfs:comment xml:lang="en">Identifies the primary resource that an issue is about, such as a reviewed resource or an ontology/module addressed as a whole; assertion-level issues are instead designated through subject, predicate, and object</rdfs:comment>
        <rdfs:label xml:lang="en">target</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Issue_tracking_system"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#IssueEntity"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#object -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#object"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#subject -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#subject"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#note -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#note"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.softlang.org/ontologies/tbox#assertedForConcept -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#assertedForConcept">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageSupportAssertion"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageConcept"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#assertedForLanguage -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#assertedForLanguage">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageSupportAssertion"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#classifies -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#classifies">
        <owl:inverseOf rdf:resource="http://www.softlang.org/ontologies/tbox#conformsTo"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#ArtifactEntity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#ArtifactEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#conformsTo -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#conformsTo">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#ArtifactEntity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#ArtifactEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#defines -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#defines">
        <owl:inverseOf rdf:resource="http://www.softlang.org/ontologies/tbox#isDefinedBy"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#ArtifactEntity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#elementOf -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#elementOf">
        <owl:inverseOf rdf:resource="http://www.softlang.org/ontologies/tbox#hasElement"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#ArtifactEntity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#extends -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#extends">
        <owl:inverseOf rdf:resource="http://www.softlang.org/ontologies/tbox#isExtendedBy"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#SoftwareLanguage"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#SoftwareLanguage"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasAffectedArtifact -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasAffectedArtifact">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#EngineeringActivity"/>
                    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#ToolEntity"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#ArtifactEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasApplicability -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasApplicability">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageSupportAssertion"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageConceptApplicability"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasArea -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasArea">
        <owl:inverseOf rdf:resource="http://www.softlang.org/ontologies/tbox#isAreaOf"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#Entity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#SubjectArea"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasArtifact -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasArtifact">
        <owl:inverseOf rdf:resource="http://www.softlang.org/ontologies/tbox#isArtifactOf"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#TechnologicalSpace"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#ArtifactEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasComponent -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasComponent">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#CompositeConcept"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageConcept"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasDominantForm -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasDominantForm">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageSupportAssertion"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageConcept"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasElement -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasElement">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageEntity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#ArtifactEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasInputArtifact -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasInputArtifact">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#EngineeringActivity"/>
                    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#ToolEntity"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#ArtifactEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasOutputArtifact -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasOutputArtifact">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#EngineeringActivity"/>
                    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#ToolEntity"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#ArtifactEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasPart -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasPart">
        <rdfs:subPropertyOf rdf:resource="http://www.softlang.org/ontologies/tbox#uses"/>
        <owl:inverseOf rdf:resource="http://www.softlang.org/ontologies/tbox#isPartOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#Entity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#Entity"/>
        <rdfs:comment xml:lang="en">Relates an ontology entity to another ontology entity that is a structural part or constituent of it</rdfs:comment>
        <rdfs:label xml:lang="en">has part</rdfs:label>
        <foaf:isPrimaryTopicOf rdf:resource="https://en.wikipedia.org/wiki/Mereology"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasPrimaryComponent -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasPrimaryComponent">
        <rdfs:subPropertyOf rdf:resource="http://www.softlang.org/ontologies/tbox#hasComponent"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#CompositeConcept"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageConcept"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasPrimaryMechanism -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasPrimaryMechanism">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageSupportAssertion"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#ImplementationMechanismConcept"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasSecondaryComponent -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasSecondaryComponent">
        <rdfs:subPropertyOf rdf:resource="http://www.softlang.org/ontologies/tbox#hasComponent"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#CompositeConcept"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageConcept"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasSpace -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasSpace">
        <owl:inverseOf rdf:resource="http://www.softlang.org/ontologies/tbox#isSpaceOf"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#Entity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#TechnologicalSpace"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasSupportKind -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasSupportKind">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageSupportAssertion"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageSupportKind"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasSupportingLanguage -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasSupportingLanguage">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#EngineeringActivity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasSupportingTool -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasSupportingTool">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#EngineeringActivity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#ToolEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#hasTool -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#hasTool">
        <owl:inverseOf rdf:resource="http://www.softlang.org/ontologies/tbox#isToolOf"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#TechnologicalSpace"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#ToolEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#isAreaOf -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#isAreaOf">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#SubjectArea"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#Entity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#isArtifactOf -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#isArtifactOf">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#ArtifactEntity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#TechnologicalSpace"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#isDefinedBy -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#isDefinedBy">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageEntity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#ArtifactEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#isExtendedBy -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#isExtendedBy">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#SoftwareLanguage"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#SoftwareLanguage"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#isPartOf -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#isPartOf">
        <rdfs:subPropertyOf rdf:resource="http://www.softlang.org/ontologies/tbox#isUsedBy"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#Entity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#Entity"/>
        <rdfs:comment xml:lang="en">Relates an ontology entity to another ontology entity of which it is a structural part or constituent</rdfs:comment>
        <rdfs:label xml:lang="en">is part of</rdfs:label>
        <foaf:isPrimaryTopicOf rdf:resource="https://en.wikipedia.org/wiki/Mereology"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#isProcessedBy -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#isProcessedBy">
        <owl:inverseOf rdf:resource="http://www.softlang.org/ontologies/tbox#processes"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#ArtifactEntity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#ToolEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#isServedBy -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#isServedBy">
        <owl:inverseOf rdf:resource="http://www.softlang.org/ontologies/tbox#serves"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#MethodologicalApproach"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#Entity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#isSpaceOf -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#isSpaceOf">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#TechnologicalSpace"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#Entity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#isSpecifiedBy -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#isSpecifiedBy">
        <owl:inverseOf rdf:resource="http://www.softlang.org/ontologies/tbox#specifies"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#FormalEntity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#MethodologicalApproach"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#isTargetedBy -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#isTargetedBy">
        <owl:inverseOf rdf:resource="http://www.softlang.org/ontologies/tbox#targets"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageEntity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#ToolEntity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#isToolOf -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#isToolOf">
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#ToolEntity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#TechnologicalSpace"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#isUsedBy -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#isUsedBy">
        <owl:inverseOf rdf:resource="http://www.softlang.org/ontologies/tbox#uses"/>
        <rdfs:domain rdf:resource="http://www.softlang.org/ontologies/tbox#Entity"/>
        <rdfs:range rdf:resource="http://www.softlang.org/ontologies/tbox#Entity"/>
    </owl:ObjectProperty>
    


    <!-- http://www.softlang.org/ontologies/tbox#nativelySupports -->


    <owl:ObjectProperty rdf:about="http://www.softlang.org/ontologies/tbox#nativelySupports">
