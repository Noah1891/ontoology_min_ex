        <rdfs:subClassOf rdf:resource="http://www.softlang.org/ontologies/tbox#SoftwareLanguage"/>
        <owl:disjointWith>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.softlang.org/ontologies/le#ConstraintLanguage"/>
                    <rdf:Description rdf:about="http://www.softlang.org/ontologies/le#DataDefinitionLanguage"/>
                    <rdf:Description rdf:about="http://www.softlang.org/ontologies/le#DataManipulationLanguage"/>
                    <rdf:Description rdf:about="http://www.softlang.org/ontologies/le#QueryLanguage"/>
                    <rdf:Description rdf:about="http://www.softlang.org/ontologies/le#TransformationLanguage"/>
                </owl:unionOf>
            </owl:Class>
        </owl:disjointWith>
    </owl:Class>
    


    <!-- http://www.softlang.org/ontologies/tbox#ArtifactEntity -->


    <owl:Class rdf:about="http://www.softlang.org/ontologies/tbox#ArtifactEntity">
        <rdfs:subClassOf rdf:resource="http://www.softlang.org/ontologies/tbox#Entity"/>
        <tbox:metamodelingPolicy xml:lang="en">All non-immediate subclasses must also be of this type.</tbox:metamodelingPolicy>
        <rdfs:comment xml:lang="en">Ontological entity used to represent software artifacts, artifact families, and artifact-related instances</rdfs:comment>
        <rdfs:label xml:lang="en">Artifact entity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.softlang.org/ontologies/tbox#Assertion -->


    <owl:Class rdf:about="http://www.softlang.org/ontologies/tbox#Assertion">
        <rdfs:subClassOf rdf:resource="http://www.softlang.org/ontologies/tbox#ConceptualEntity"/>
        <rdfs:comment xml:lang="en">Reified assertion entity used for qualified statements in language-related modules</rdfs:comment>
        <rdfs:label xml:lang="en">Assertion</rdfs:label>
        <foaf:isPrimaryTopicOf rdf:resource="https://en.wikipedia.org/wiki/Reification_(knowledge_representation)"/>
    </owl:Class>
    


    <!-- http://www.softlang.org/ontologies/tbox#CompositeConcept -->


    <owl:Class rdf:about="http://www.softlang.org/ontologies/tbox#CompositeConcept">
        <rdfs:subClassOf rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageConcept"/>
    </owl:Class>
    


    <!-- http://www.softlang.org/ontologies/tbox#ConceptualEntity -->


    <owl:Class rdf:about="http://www.softlang.org/ontologies/tbox#ConceptualEntity">
        <rdfs:subClassOf rdf:resource="http://www.softlang.org/ontologies/tbox#Entity"/>
        <tbox:metamodelingPolicy xml:lang="en">All non-immediate subclasses must also be of this type.</tbox:metamodelingPolicy>
        <rdfs:comment xml:lang="en">Contextual concepts for other entity types (foundations, languages, tools, and artifacts)</rdfs:comment>
        <rdfs:label xml:lang="en">Conceptual entity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.softlang.org/ontologies/tbox#EngineeringActivity -->


    <owl:Class rdf:about="http://www.softlang.org/ontologies/tbox#EngineeringActivity">
        <rdfs:subClassOf rdf:resource="http://www.softlang.org/ontologies/tbox#ConceptualEntity"/>
    </owl:Class>
    


    <!-- http://www.softlang.org/ontologies/tbox#Entity -->


    <owl:Class rdf:about="http://www.softlang.org/ontologies/tbox#Entity">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://xmlns.com/foaf/0.1/isPrimaryTopicOf"/>
                        <owl:someValuesFrom rdf:resource="http://xmlns.com/foaf/0.1/Document"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://xmlns.com/foaf/0.1/page"/>
                        <owl:someValuesFrom rdf:resource="http://xmlns.com/foaf/0.1/Document"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Top-level category for entities represented in this ontology. Entities should be linked to at least one descriptive document via foaf:isPrimaryTopicOf or foaf:page.</rdfs:comment>
        <rdfs:label xml:lang="en">Entity</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Knowledge_representation_and_reasoning"/>
    </owl:Class>
    


    <!-- http://www.softlang.org/ontologies/tbox#FormalEntity -->


    <owl:Class rdf:about="http://www.softlang.org/ontologies/tbox#FormalEntity">
        <rdfs:subClassOf rdf:resource="http://www.softlang.org/ontologies/tbox#Entity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.softlang.org/ontologies/tbox#hasArea"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.softlang.org/ontologies/tbox#SubjectArea"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.softlang.org/ontologies/tbox#hasSpace"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.softlang.org/ontologies/tbox#TechnologicalSpace"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <tbox:metamodelingPolicy xml:lang="en">All non-immediate subclasses must also be of this type.</tbox:metamodelingPolicy>
        <rdfs:comment xml:lang="en">Ontological entity used to represent formal formalisms, theories, models of computation, and methodological approaches</rdfs:comment>
        <rdfs:label xml:lang="en">Formal entity</rdfs:label>
    </owl:Class>
    


