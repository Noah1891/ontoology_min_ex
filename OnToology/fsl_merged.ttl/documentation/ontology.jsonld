    "@language" : "en",
    "@value" : "All non-immediate subclasses must also be of this type."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Ontological entity used to represent software tools, tool families, and tool-related instances"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Tool entity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.softlang.org/ontologies/tbox#Entity"
  } ]
