    <oops:hasNumberAffectedElements rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</oops:hasNumberAffectedElements>
    <oops:hasImportanceLevel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Minor</oops:hasImportanceLevel>
    <oops:hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A class whose name refers to two or more different concepts is created.	</oops:hasDescription>
    <rdf:type rdf:resource="http://oops.linkeddata.es/def#pitfall"/>
    <oops:hasAffectedElement rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.softlang.org/ontologies/ce#TrainingAndOnboarding</oops:hasAffectedElement>
    <oops:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Merging different concepts in the same class</oops:hasName>
    <oops:hasAffectedElement rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.softlang.org/ontologies/ce#VerificationAndValidationActivity</oops:hasAffectedElement>
    <oops:hasAffectedElement rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.softlang.org/ontologies/ce#ReleaseAndDeploymentActivity</oops:hasAffectedElement>
  </rdf:Description>
