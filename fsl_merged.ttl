@prefix : <http://www.softlang.org/ontologies/fsl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tbox: <http://www.softlang.org/ontologies/tbox#> .
@base <http://www.softlang.org/ontologies/fsl> .

<http://www.softlang.org/ontologies/fsl> rdf:type owl:Ontology ;
                                          tbox:commentingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                          tbox:formattingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                          tbox:linkingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                          tbox:metamodelingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                          rdfs:comment "Ontology on the foundations of software languages"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://www.softlang.org/ontologies/pe#profilingPolicy
<http://www.softlang.org/ontologies/pe#profilingPolicy> rdf:type owl:AnnotationProperty ;
                                                        rdfs:label "profiling policy"@en .


###  http://www.softlang.org/ontologies/tbox#commentingPolicy
tbox:commentingPolicy rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#formattingPolicy
tbox:formattingPolicy rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#linkingPolicy
tbox:linkingPolicy rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#metamodelingPolicy
tbox:metamodelingPolicy rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#object
tbox:object rdfs:comment "Identifies the object constituent of an issue when the issue concerns a particular assertion; this property designates object role rather than the overall issue target"@en ;
            rdfs:label "object"@en ;
            <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Issue_tracking_system> ;
            rdf:type owl:AnnotationProperty ;
            rdfs:subPropertyOf rdf:object ;
            rdfs:domain tbox:IssueEntity .


###  http://www.softlang.org/ontologies/tbox#predicate
tbox:predicate rdfs:comment "Identifies the predicate constituent of an issue when the issue concerns a particular assertion; this property designates predicate role rather than the overall issue target"@en ;
               rdfs:label "predicate"@en ;
               <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Issue_tracking_system> ;
               rdf:type owl:AnnotationProperty ;
               rdfs:subPropertyOf rdf:predicate ;
               rdfs:domain tbox:IssueEntity .


###  http://www.softlang.org/ontologies/tbox#subject
tbox:subject rdfs:comment "Identifies the subject constituent of an issue when the issue concerns a particular assertion; this property designates subject role rather than the overall issue target"@en ;
             rdfs:label "subject"@en ;
             <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Issue_tracking_system> ;
             rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf rdf:subject ;
             rdfs:domain tbox:IssueEntity .


###  http://www.softlang.org/ontologies/tbox#target
tbox:target rdfs:comment "Identifies the primary resource that an issue is about, such as a reviewed resource or an ontology/module addressed as a whole; assertion-level issues are instead designated through subject, predicate, and object"@en ;
            rdfs:label "target"@en ;
            <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Issue_tracking_system> ;
            rdf:type owl:AnnotationProperty ;
            rdfs:domain tbox:IssueEntity .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#object
rdf:object rdf:type owl:AnnotationProperty .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate
rdf:predicate rdf:type owl:AnnotationProperty .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#subject
rdf:subject rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#note
<http://www.w3.org/2004/02/skos/core#note> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.softlang.org/ontologies/tbox#assertedForConcept
tbox:assertedForConcept rdf:type owl:ObjectProperty ;
                        rdfs:domain tbox:LanguageSupportAssertion ;
                        rdfs:range tbox:LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#assertedForLanguage
tbox:assertedForLanguage rdf:type owl:ObjectProperty ;
                         rdfs:domain tbox:LanguageSupportAssertion ;
                         rdfs:range tbox:LanguageEntity .


###  http://www.softlang.org/ontologies/tbox#classifies
tbox:classifies rdf:type owl:ObjectProperty ;
                owl:inverseOf tbox:conformsTo ;
                rdfs:domain tbox:ArtifactEntity ;
                rdfs:range tbox:ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#conformsTo
tbox:conformsTo rdf:type owl:ObjectProperty ;
                rdfs:domain tbox:ArtifactEntity ;
                rdfs:range tbox:ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#defines
tbox:defines rdf:type owl:ObjectProperty ;
             owl:inverseOf tbox:isDefinedBy ;
             rdfs:domain tbox:ArtifactEntity ;
             rdfs:range tbox:LanguageEntity .


###  http://www.softlang.org/ontologies/tbox#elementOf
tbox:elementOf rdf:type owl:ObjectProperty ;
               owl:inverseOf tbox:hasElement ;
               rdfs:domain tbox:ArtifactEntity ;
               rdfs:range tbox:LanguageEntity .


###  http://www.softlang.org/ontologies/tbox#extends
tbox:extends rdf:type owl:ObjectProperty ;
             owl:inverseOf tbox:isExtendedBy ;
             rdfs:domain tbox:SoftwareLanguage ;
             rdfs:range tbox:SoftwareLanguage .


###  http://www.softlang.org/ontologies/tbox#hasAffectedArtifact
tbox:hasAffectedArtifact rdf:type owl:ObjectProperty ;
                         rdfs:domain [ rdf:type owl:Class ;
                                       owl:unionOf ( tbox:EngineeringActivity
                                                     tbox:ToolEntity
                                                   )
                                     ] ;
                         rdfs:range tbox:ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#hasApplicability
tbox:hasApplicability rdf:type owl:ObjectProperty ;
                      rdfs:domain tbox:LanguageSupportAssertion ;
                      rdfs:range tbox:LanguageConceptApplicability .


###  http://www.softlang.org/ontologies/tbox#hasArea
tbox:hasArea rdf:type owl:ObjectProperty ;
             owl:inverseOf tbox:isAreaOf ;
             rdfs:domain tbox:Entity ;
             rdfs:range tbox:SubjectArea .


###  http://www.softlang.org/ontologies/tbox#hasArtifact
tbox:hasArtifact rdf:type owl:ObjectProperty ;
                 owl:inverseOf tbox:isArtifactOf ;
                 rdfs:domain tbox:TechnologicalSpace ;
                 rdfs:range tbox:ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#hasComponent
tbox:hasComponent rdf:type owl:ObjectProperty ;
                  rdfs:domain tbox:CompositeConcept ;
                  rdfs:range tbox:LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#hasDominantForm
tbox:hasDominantForm rdf:type owl:ObjectProperty ;
                     rdfs:domain tbox:LanguageSupportAssertion ;
                     rdfs:range tbox:LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#hasElement
tbox:hasElement rdf:type owl:ObjectProperty ;
                rdfs:domain tbox:LanguageEntity ;
                rdfs:range tbox:ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#hasInputArtifact
tbox:hasInputArtifact rdf:type owl:ObjectProperty ;
                      rdfs:domain [ rdf:type owl:Class ;
                                    owl:unionOf ( tbox:EngineeringActivity
                                                  tbox:ToolEntity
                                                )
                                  ] ;
                      rdfs:range tbox:ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#hasOutputArtifact
tbox:hasOutputArtifact rdf:type owl:ObjectProperty ;
                       rdfs:domain [ rdf:type owl:Class ;
                                     owl:unionOf ( tbox:EngineeringActivity
                                                   tbox:ToolEntity
                                                 )
                                   ] ;
                       rdfs:range tbox:ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#hasPart
tbox:hasPart rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf tbox:uses ;
             owl:inverseOf tbox:isPartOf ;
             rdf:type owl:AsymmetricProperty ,
                      owl:IrreflexiveProperty ;
             rdfs:domain tbox:Entity ;
             rdfs:range tbox:Entity ;
             rdfs:comment "Relates an ontology entity to another ontology entity that is a structural part or constituent of it"@en ;
             rdfs:label "has part"@en ;
             <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Mereology> .


###  http://www.softlang.org/ontologies/tbox#hasPrimaryComponent
tbox:hasPrimaryComponent rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf tbox:hasComponent ;
                         rdfs:domain tbox:CompositeConcept ;
                         rdfs:range tbox:LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#hasPrimaryMechanism
tbox:hasPrimaryMechanism rdf:type owl:ObjectProperty ;
                         rdfs:domain tbox:LanguageSupportAssertion ;
                         rdfs:range tbox:ImplementationMechanismConcept .


###  http://www.softlang.org/ontologies/tbox#hasSecondaryComponent
tbox:hasSecondaryComponent rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf tbox:hasComponent ;
                           rdfs:domain tbox:CompositeConcept ;
                           rdfs:range tbox:LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#hasSpace
tbox:hasSpace rdf:type owl:ObjectProperty ;
              owl:inverseOf tbox:isSpaceOf ;
              rdfs:domain tbox:Entity ;
              rdfs:range tbox:TechnologicalSpace .


###  http://www.softlang.org/ontologies/tbox#hasSupportKind
tbox:hasSupportKind rdf:type owl:ObjectProperty ;
                    rdfs:domain tbox:LanguageSupportAssertion ;
                    rdfs:range tbox:LanguageSupportKind .


###  http://www.softlang.org/ontologies/tbox#hasSupportingLanguage
tbox:hasSupportingLanguage rdf:type owl:ObjectProperty ;
                           rdfs:domain tbox:EngineeringActivity ;
                           rdfs:range tbox:LanguageEntity .


###  http://www.softlang.org/ontologies/tbox#hasSupportingTool
tbox:hasSupportingTool rdf:type owl:ObjectProperty ;
                       rdfs:domain tbox:EngineeringActivity ;
                       rdfs:range tbox:ToolEntity .


###  http://www.softlang.org/ontologies/tbox#hasTool
tbox:hasTool rdf:type owl:ObjectProperty ;
             owl:inverseOf tbox:isToolOf ;
             rdfs:domain tbox:TechnologicalSpace ;
             rdfs:range tbox:ToolEntity .


###  http://www.softlang.org/ontologies/tbox#isAreaOf
tbox:isAreaOf rdf:type owl:ObjectProperty ;
              rdfs:domain tbox:SubjectArea ;
              rdfs:range tbox:Entity .


###  http://www.softlang.org/ontologies/tbox#isArtifactOf
tbox:isArtifactOf rdf:type owl:ObjectProperty ;
                  rdfs:domain tbox:ArtifactEntity ;
                  rdfs:range tbox:TechnologicalSpace .


###  http://www.softlang.org/ontologies/tbox#isDefinedBy
tbox:isDefinedBy rdf:type owl:ObjectProperty ;
                 rdfs:domain tbox:LanguageEntity ;
                 rdfs:range tbox:ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#isExtendedBy
tbox:isExtendedBy rdf:type owl:ObjectProperty ;
                  rdfs:domain tbox:SoftwareLanguage ;
                  rdfs:range tbox:SoftwareLanguage .


###  http://www.softlang.org/ontologies/tbox#isPartOf
tbox:isPartOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf tbox:isUsedBy ;
              rdf:type owl:AsymmetricProperty ,
                       owl:IrreflexiveProperty ;
              rdfs:domain tbox:Entity ;
              rdfs:range tbox:Entity ;
              rdfs:comment "Relates an ontology entity to another ontology entity of which it is a structural part or constituent"@en ;
              rdfs:label "is part of"@en ;
              <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Mereology> .


###  http://www.softlang.org/ontologies/tbox#isProcessedBy
tbox:isProcessedBy rdf:type owl:ObjectProperty ;
                   owl:inverseOf tbox:processes ;
                   rdfs:domain tbox:ArtifactEntity ;
                   rdfs:range tbox:ToolEntity .


###  http://www.softlang.org/ontologies/tbox#isServedBy
tbox:isServedBy rdf:type owl:ObjectProperty ;
                owl:inverseOf tbox:serves ;
                rdfs:domain tbox:MethodologicalApproach ;
                rdfs:range tbox:Entity .


###  http://www.softlang.org/ontologies/tbox#isSpaceOf
tbox:isSpaceOf rdf:type owl:ObjectProperty ;
               rdfs:domain tbox:TechnologicalSpace ;
               rdfs:range tbox:Entity .


###  http://www.softlang.org/ontologies/tbox#isSpecifiedBy
tbox:isSpecifiedBy rdf:type owl:ObjectProperty ;
                   owl:inverseOf tbox:specifies ;
                   rdfs:domain tbox:FormalEntity ;
                   rdfs:range tbox:MethodologicalApproach .


###  http://www.softlang.org/ontologies/tbox#isTargetedBy
tbox:isTargetedBy rdf:type owl:ObjectProperty ;
                  owl:inverseOf tbox:targets ;
                  rdfs:domain tbox:LanguageEntity ;
                  rdfs:range tbox:ToolEntity .


###  http://www.softlang.org/ontologies/tbox#isToolOf
tbox:isToolOf rdf:type owl:ObjectProperty ;
              rdfs:domain tbox:ToolEntity ;
              rdfs:range tbox:TechnologicalSpace .


###  http://www.softlang.org/ontologies/tbox#isUsedBy
tbox:isUsedBy rdf:type owl:ObjectProperty ;
              owl:inverseOf tbox:uses ;
              rdfs:domain tbox:Entity ;
              rdfs:range tbox:Entity .


###  http://www.softlang.org/ontologies/tbox#nativelySupports
tbox:nativelySupports rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf tbox:supports ;
                      rdfs:domain tbox:LanguageEntity ;
                      rdfs:range tbox:LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#processes
tbox:processes rdf:type owl:ObjectProperty ;
               rdfs:domain tbox:ToolEntity ;
               rdfs:range tbox:ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#resolveAfter
tbox:resolveAfter rdf:type owl:ObjectProperty ;
                  rdfs:domain tbox:IssueEntity ;
                  rdfs:range tbox:IssueEntity .


###  http://www.softlang.org/ontologies/tbox#serves
tbox:serves rdf:type owl:ObjectProperty ;
            rdfs:domain tbox:Entity ;
            rdfs:range tbox:MethodologicalApproach .


###  http://www.softlang.org/ontologies/tbox#specifies
tbox:specifies rdf:type owl:ObjectProperty ;
               rdfs:domain tbox:MethodologicalApproach ;
               rdfs:range tbox:FormalEntity .


###  http://www.softlang.org/ontologies/tbox#standardlySupports
tbox:standardlySupports rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf tbox:supports ;
                        rdfs:domain tbox:LanguageEntity ;
                        rdfs:range tbox:LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#supports
tbox:supports rdf:type owl:ObjectProperty ;
              rdfs:domain tbox:LanguageEntity ;
              rdfs:range tbox:LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#targets
tbox:targets rdf:type owl:ObjectProperty ;
             rdfs:domain tbox:ToolEntity ;
             rdfs:range tbox:LanguageEntity .


###  http://www.softlang.org/ontologies/tbox#uses
tbox:uses rdf:type owl:ObjectProperty ;
          rdfs:domain tbox:Entity ;
          rdfs:range tbox:Entity .


#################################################################
#    Data properties
#################################################################

###  http://www.softlang.org/ontologies/tbox#critique
tbox:critique rdf:type owl:DatatypeProperty ;
              rdfs:domain tbox:IssueEntity ;
              rdfs:range rdf:langString .


###  http://www.softlang.org/ontologies/tbox#hasBibTeX
tbox:hasBibTeX rdf:type owl:DatatypeProperty ;
               rdfs:domain tbox:Entity ;
               rdfs:range xsd:string .


###  http://www.softlang.org/ontologies/tbox#suggestion
tbox:suggestion rdf:type owl:DatatypeProperty ;
                rdfs:domain tbox:IssueEntity ;
                rdfs:range rdf:langString .


#################################################################
#    Classes
#################################################################

###  http://www.softlang.org/ontologies/ae#APIDescriptionArtifact
<http://www.softlang.org/ontologies/ae#APIDescriptionArtifact> rdf:type owl:Class ;
                                                               rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#BuildScriptArtifact
<http://www.softlang.org/ontologies/ae#BuildScriptArtifact> rdf:type owl:Class ;
                                                            rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#ConfigurationArtifact
<http://www.softlang.org/ontologies/ae#ConfigurationArtifact> rdf:type owl:Class ;
                                                              rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#GrammarArtifact
<http://www.softlang.org/ontologies/ae#GrammarArtifact> rdf:type owl:Class ;
                                                        rdfs:subClassOf tbox:SoftwareArtifact ;
                                                        owl:disjointWith <http://www.softlang.org/ontologies/ae#MetamodelArtifact> .


###  http://www.softlang.org/ontologies/ae#GrammarOfGrammarsArtifact
<http://www.softlang.org/ontologies/ae#GrammarOfGrammarsArtifact> rdf:type owl:Class ;
                                                                  rdfs:subClassOf tbox:SoftwareArtifact ;
                                                                  owl:disjointWith <http://www.softlang.org/ontologies/ae#MetamodelArtifact> .


###  http://www.softlang.org/ontologies/ae#GraphQueryArtifact
<http://www.softlang.org/ontologies/ae#GraphQueryArtifact> rdf:type owl:Class ;
                                                           rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#JSONDocumentArtifact
<http://www.softlang.org/ontologies/ae#JSONDocumentArtifact> rdf:type owl:Class ;
                                                             rdfs:subClassOf tbox:SoftwareArtifact ;
                                                             owl:disjointWith <http://www.softlang.org/ontologies/ae#XMLDocumentArtifact> .


###  http://www.softlang.org/ontologies/ae#JSONSchemaArtifact
<http://www.softlang.org/ontologies/ae#JSONSchemaArtifact> rdf:type owl:Class ;
                                                           rdfs:subClassOf tbox:SoftwareArtifact ;
                                                           owl:disjointWith <http://www.softlang.org/ontologies/ae#XMLSchemaArtifact> .


###  http://www.softlang.org/ontologies/ae#LogicProgramArtifact
<http://www.softlang.org/ontologies/ae#LogicProgramArtifact> rdf:type owl:Class ;
                                                             rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#MarkupArtifact
<http://www.softlang.org/ontologies/ae#MarkupArtifact> rdf:type owl:Class ;
                                                       rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#MegamodelArtifact
<http://www.softlang.org/ontologies/ae#MegamodelArtifact> rdf:type owl:Class ;
                                                          rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#MetamodelArtifact
<http://www.softlang.org/ontologies/ae#MetamodelArtifact> rdf:type owl:Class ;
                                                          rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#ModelArtifact
<http://www.softlang.org/ontologies/ae#ModelArtifact> rdf:type owl:Class ;
                                                      rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#OntologyArtifact
<http://www.softlang.org/ontologies/ae#OntologyArtifact> rdf:type owl:Class ;
                                                         rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#ProgramArtifact
<http://www.softlang.org/ontologies/ae#ProgramArtifact> rdf:type owl:Class ;
                                                        rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#ProofArtifact
<http://www.softlang.org/ontologies/ae#ProofArtifact> rdf:type owl:Class ;
                                                      rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#PropertyGraphArtifact
<http://www.softlang.org/ontologies/ae#PropertyGraphArtifact> rdf:type owl:Class ;
                                                              rdfs:subClassOf <http://www.softlang.org/ontologies/ae#SemanticDataArtifact> .


###  http://www.softlang.org/ontologies/ae#RDFGraphArtifact
<http://www.softlang.org/ontologies/ae#RDFGraphArtifact> rdf:type owl:Class ;
                                                         rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#RelationalDataArtifact
<http://www.softlang.org/ontologies/ae#RelationalDataArtifact> rdf:type owl:Class ;
                                                               rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#RelationalQueryArtifact
<http://www.softlang.org/ontologies/ae#RelationalQueryArtifact> rdf:type owl:Class ;
                                                                rdfs:subClassOf <http://www.softlang.org/ontologies/ae#SemanticDataArtifact> .


###  http://www.softlang.org/ontologies/ae#RelationalSchemaArtifact
<http://www.softlang.org/ontologies/ae#RelationalSchemaArtifact> rdf:type owl:Class ;
                                                                 rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#RequirementsArtifact
<http://www.softlang.org/ontologies/ae#RequirementsArtifact> rdf:type owl:Class ;
                                                             rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#RuleArtifact
<http://www.softlang.org/ontologies/ae#RuleArtifact> rdf:type owl:Class ;
                                                     rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#SemanticDataArtifact
<http://www.softlang.org/ontologies/ae#SemanticDataArtifact> rdf:type owl:Class ;
                                                             rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#ShapeArtifact
<http://www.softlang.org/ontologies/ae#ShapeArtifact> rdf:type owl:Class ;
                                                      rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#XMLDocumentArtifact
<http://www.softlang.org/ontologies/ae#XMLDocumentArtifact> rdf:type owl:Class ;
                                                            rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ae#XMLSchemaArtifact
<http://www.softlang.org/ontologies/ae#XMLSchemaArtifact> rdf:type owl:Class ;
                                                          rdfs:subClassOf tbox:SoftwareArtifact .


###  http://www.softlang.org/ontologies/ce#APIDesign
<http://www.softlang.org/ontologies/ce#APIDesign> rdf:type owl:Class ;
                                                  rdfs:subClassOf <http://www.softlang.org/ontologies/ce#InterfaceDesign> .


###  http://www.softlang.org/ontologies/ce#AbstractionConcept
<http://www.softlang.org/ontologies/ce#AbstractionConcept> rdf:type owl:Class ;
                                                           rdfs:subClassOf <http://www.softlang.org/ontologies/ce#PrimitiveConcept> .


###  http://www.softlang.org/ontologies/ce#AcceptanceTesting
<http://www.softlang.org/ontologies/ce#AcceptanceTesting> rdf:type owl:Class ;
                                                          rdfs:subClassOf <http://www.softlang.org/ontologies/ce#ValidationTestingActivity> .


###  http://www.softlang.org/ontologies/ce#Auditing
<http://www.softlang.org/ontologies/ce#Auditing> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://www.softlang.org/ontologies/ce#QualityAndGovernanceActivity> .


###  http://www.softlang.org/ontologies/ce#BackupAndRecovery
<http://www.softlang.org/ontologies/ce#BackupAndRecovery> rdf:type owl:Class ;
                                                          rdfs:subClassOf <http://www.softlang.org/ontologies/ce#OperationsAndMaintenanceActivity> .


###  http://www.softlang.org/ontologies/ce#BindingConcept
<http://www.softlang.org/ontologies/ce#BindingConcept> rdf:type owl:Class ;
                                                       rdfs:subClassOf <http://www.softlang.org/ontologies/ce#PrimitiveConcept> .


###  http://www.softlang.org/ontologies/ce#BugFixing
<http://www.softlang.org/ontologies/ce#BugFixing> rdf:type owl:Class ;
                                                  rdfs:subClassOf <http://www.softlang.org/ontologies/ce#OperationsAndMaintenanceActivity> .


###  http://www.softlang.org/ontologies/ce#BuildScripting
