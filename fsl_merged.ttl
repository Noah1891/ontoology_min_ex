                      rdfs:subClassOf tbox:Entity ;
                      tbox:metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
                      rdfs:comment "Contextual concepts for other entity types (foundations, languages, tools, and artifacts)"@en ;
                      rdfs:label "Conceptual entity"@en .


###  http://www.softlang.org/ontologies/tbox#EngineeringActivity
tbox:EngineeringActivity rdf:type owl:Class ;
                         rdfs:subClassOf tbox:ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#Entity
tbox:Entity rdf:type owl:Class ;
            rdfs:subClassOf [ rdf:type owl:Class ;
                              owl:unionOf ( [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> ;
                                              owl:someValuesFrom <http://xmlns.com/foaf/0.1/Document>
                                            ]
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://xmlns.com/foaf/0.1/page> ;
                                              owl:someValuesFrom <http://xmlns.com/foaf/0.1/Document>
                                            ]
                                          )
                            ] ;
            rdfs:comment "Top-level category for entities represented in this ontology. Entities should be linked to at least one descriptive document via foaf:isPrimaryTopicOf or foaf:page."@en ;
            rdfs:label "Entity"@en ;
            <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Knowledge_representation_and_reasoning> .


###  http://www.softlang.org/ontologies/tbox#FormalEntity
tbox:FormalEntity rdf:type owl:Class ;
                  rdfs:subClassOf tbox:Entity ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty tbox:hasArea ;
                                    owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass tbox:SubjectArea
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty tbox:hasSpace ;
                                    owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass tbox:TechnologicalSpace
                                  ] ;
                  tbox:metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
                  rdfs:comment "Ontological entity used to represent formal formalisms, theories, models of computation, and methodological approaches"@en ;
                  rdfs:label "Formal entity"@en .


###  http://www.softlang.org/ontologies/tbox#ImplementationMechanismConcept
tbox:ImplementationMechanismConcept rdf:type owl:Class ;
                                    rdfs:subClassOf tbox:LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#IssueEntity
tbox:IssueEntity rdf:type owl:Class ;
                 rdfs:subClassOf tbox:Entity ;
                 rdfs:comment "Entity for representing review issues, critiques, and proposed resolutions concerning resources, predicates, or fully specified assertions in the ontology"@en ;
                 rdfs:label "Issue entity"@en ;
                 <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Issue_tracking_system> .


###  http://www.softlang.org/ontologies/tbox#LanguageConcept
tbox:LanguageConcept rdf:type owl:Class ;
                     rdfs:subClassOf tbox:ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#LanguageConceptApplicability
tbox:LanguageConceptApplicability rdf:type owl:Class ;
                                  rdfs:subClassOf tbox:ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#LanguageEntity
tbox:LanguageEntity rdf:type owl:Class ;
                    rdfs:subClassOf tbox:Entity ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty tbox:hasArea ;
                                      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass tbox:SubjectArea
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty tbox:hasSpace ;
                                      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass tbox:TechnologicalSpace
                                    ] ;
                    tbox:metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
                    rdfs:comment "Ontological entity used to represent software languages, language families, and language-related instances"@en ;
                    rdfs:label "Language entity"@en .


###  http://www.softlang.org/ontologies/tbox#LanguageSupportAssertion
tbox:LanguageSupportAssertion rdf:type owl:Class ;
                              rdfs:subClassOf tbox:Assertion .


###  http://www.softlang.org/ontologies/tbox#LanguageSupportKind
tbox:LanguageSupportKind rdf:type owl:Class ;
                         rdfs:subClassOf tbox:ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#MethodologicalApproach
tbox:MethodologicalApproach rdf:type owl:Class ;
                            rdfs:subClassOf tbox:FormalEntity .


###  http://www.softlang.org/ontologies/tbox#PropertyEntity
tbox:PropertyEntity rdf:type owl:Class ;
                    rdfs:subClassOf tbox:Entity ;
                    rdfs:comment "Ontological entity used to represent property declarations that participate in relations like other modeled entities"@en ;
                    rdfs:label "Property entity"@en .


###  http://www.softlang.org/ontologies/tbox#SoftwareArtifact
tbox:SoftwareArtifact rdf:type owl:Class ;
                      rdfs:subClassOf tbox:ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#SoftwareLanguage
tbox:SoftwareLanguage rdf:type owl:Class ;
                      rdfs:subClassOf tbox:LanguageEntity .


###  http://www.softlang.org/ontologies/tbox#SoftwareTool
tbox:SoftwareTool rdf:type owl:Class ;
