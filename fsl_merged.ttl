###  http://www.softlang.org/ontologies/tbox#SubjectArea
tbox:SubjectArea rdf:type owl:Class ;
                 rdfs:subClassOf tbox:ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#TechnologicalSpace
tbox:TechnologicalSpace rdf:type owl:Class ;
                        rdfs:subClassOf tbox:ConceptualEntity .


