tbox:ToolEntity rdf:type owl:Class ;
                rdfs:subClassOf tbox:Entity ;
                tbox:metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
                rdfs:comment "Ontological entity used to represent software tools, tool families, and tool-related instances"@en ;
                rdfs:label "Tool entity"@en .


